{
  "trailingSlash": false,
  "rewrites": [
    { "source": "/seal", "destination": "/seal.html" },
    { "source": "/((?!api/|.*\\.).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
