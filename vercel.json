{
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "https://dev-api.os.axeumai.com/api/public/verify/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" }
      ]
    }
  ]
}
